<section class="early-access" id="early-access">
  <div class="container">
    <div class="ea-card">
      <div class="ea-glow"></div>
      <div class="ea-content">
        <div class="badge">Acceso anticipado</div>
        <h2>Sé de los primeros en usar SubliFlow</h2>
        <p>
          Estamos abriendo acceso anticipado para talleres de sublimación.
          Regístrate y te avisamos cuando tu cuenta esté lista — sin costo durante el beta.
        </p>
        <form class="ea-form" id="waitlist-form">
          <input
            type="email"
            placeholder="tu@email.com"
            class="ea-input"
            required
          />
          <button type="submit" class="btn btn-primary">
            Quiero acceso
          </button>
        </form>
        <p class="ea-note">Sin tarjeta de crédito. Sin compromisos.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .early-access {
    padding: 80px 0;
  }

  .ea-card {
    position: relative;
    background: var(--color-surface);
    border: 1px solid rgba(108, 99, 255, 0.3);
    border-radius: 20px;
    padding: 72px 48px;
    text-align: center;
    overflow: hidden;
  }

  .ea-glow {
    position: absolute;
    top: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(108, 99, 255, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .ea-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  h2 {
    max-width: 500px;
  }

  .ea-content p {
    font-size: 17px;
    color: var(--color-text-muted);
    max-width: 480px;
    line-height: 1.7;
  }

  .ea-form {
    display: flex;
    gap: 10px;
    width: 100%;
    max-width: 460px;
  }

  .ea-input {
    flex: 1;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 14px 18px;
    color: var(--color-text);
    font-size: 15px;
    outline: none;
    transition: border-color 0.2s;
  }

  .ea-input::placeholder {
    color: var(--color-text-subtle);
  }

  .ea-input:focus {
    border-color: var(--color-primary);
  }

  .ea-note {
    font-size: 13px !important;
    color: var(--color-text-subtle) !important;
  }

  @media (max-width: 600px) {
    .ea-card { padding: 48px 24px; }
    .ea-form { flex-direction: column; }
  }
</style>
