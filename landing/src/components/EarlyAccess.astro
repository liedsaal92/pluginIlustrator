---
---

<section class="cta-section" id="waitlist">

  <!-- Giant text block -->
  <div class="cta-headline-block">
    <div class="cta-label">
      <span class="cta-tag">Acceso anticipado abierto</span>
      <div class="cta-label-line"></div>
    </div>
    <h2 class="cta-headline">
      ¿Listo para producir<br/>
      <span class="cta-hl-yellow">3× más rápido?</span>
    </h2>
  </div>

  <!-- Form + social proof row -->
  <div class="cta-bottom">

    <div class="cta-form-block">
      <p class="cta-sub">
        Sin tarjeta de crédito. Sin compromisos.<br/>
        Beta gratuito hasta que estemos listos para lanzar.
      </p>

      <form class="cta-form" id="waitlist-form">
        <div class="cta-form-row">
          <input
            type="email"
            placeholder="hola@mitaller.com"
            class="cta-input"
            required
            aria-label="Tu correo electrónico"
          />
          <button type="submit" class="btn btn-yellow btn-lg cta-submit">
            Quiero acceso →
          </button>
        </div>
        <p class="cta-privacy">
          Sin spam. Solo te avisamos cuando tu acceso esté listo.
        </p>
      </form>
    </div>

    <div class="cta-proof-block">
      <div class="proof-row">
        <div class="proof-big">+120</div>
        <div class="proof-label">talleres en<br/>lista de espera</div>
      </div>
      <div class="proof-divider"></div>
      <div class="proof-row">
        <div class="proof-big green">Beta</div>
        <div class="proof-label">gratuito<br/>sin límite de tiempo</div>
      </div>
    </div>

  </div>

</section>

<style>
  .cta-section {
    background: #0D0D0D;
    border-bottom: 3px solid #0D0D0D;
  }

  /* ─── Headline block ──────────────────── */
  .cta-headline-block {
    border-bottom: 3px solid #222;
    padding: 72px 56px 64px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .cta-label {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 32px;
  }

  .cta-tag {
    display: inline-block;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 5px 14px;
    border: 3px solid #FFE600;
    background: transparent;
    color: #FFE600;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .cta-label-line {
    flex: 1;
    height: 2px;
    background: #222;
  }

  .cta-headline {
    font-size: clamp(48px, 7vw, 96px);
    font-weight: 800;
    line-height: 1.0;
    letter-spacing: -2px;
    color: #fff;
  }

  .cta-hl-yellow {
    color: #FFE600;
    display: inline-block;
  }

  /* ─── Bottom row ──────────────────────── */
  .cta-bottom {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0;
    max-width: 1200px;
    margin: 0 auto;
    padding: 64px 56px;
    align-items: center;
  }

  /* ─── Form ────────────────────────────── */
  .cta-form-block {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 560px;
  }

  .cta-sub {
    font-size: 17px;
    color: #777;
    line-height: 1.6;
  }

  .cta-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .cta-form-row {
    display: flex;
    gap: 0;
  }

  .cta-input {
    flex: 1;
    background: #fff;
    border: 3px solid #FFE600;
    border-right: none;
    padding: 0 20px;
    font-size: 15px;
    font-family: 'Space Grotesk', system-ui, sans-serif;
    color: #0D0D0D;
    outline: none;
    height: 60px;
    border-radius: 0;
  }

  .cta-input::placeholder { color: #aaa; }
  .cta-input:focus { background: #FFFCF0; }

  .cta-submit {
    border-left: none;
    height: 60px;
    padding: 0 32px;
    white-space: nowrap;
    flex-shrink: 0;
    box-shadow: 5px 5px 0 #FFE600;
  }

  .cta-privacy {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: #555;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ─── Proof ───────────────────────────── */
  .cta-proof-block {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 3px solid #333;
    min-width: 220px;
  }

  .proof-row {
    padding: 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .proof-divider {
    height: 3px;
    background: #333;
  }

  .proof-big {
    font-size: 48px;
    font-weight: 800;
    line-height: 1;
    color: #FFE600;
    letter-spacing: -1px;
  }

  .proof-big.green { color: #00CC88; }

  .proof-label {
    font-size: 13px;
    color: #666;
    line-height: 1.4;
    font-family: 'DM Mono', monospace;
  }

  /* ─── Responsive ──────────────────────── */
  @media (max-width: 900px) {
    .cta-bottom {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .cta-proof-block {
      flex-direction: row;
      min-width: unset;
    }
    .proof-divider { width: 3px; height: auto; }
    .proof-row { flex: 1; }
    .cta-headline-block { padding: 56px 32px 48px; }
    .cta-bottom { padding: 48px 32px; }
  }

  @media (max-width: 600px) {
    .cta-form-row { flex-direction: column; }
    .cta-input { border-right: 3px solid #FFE600; border-bottom: none; }
    .cta-input:last-child { border-bottom: 3px solid #FFE600; }
    .cta-submit { height: 56px; border-left: 3px solid #FFE600; }
    .cta-proof-block { flex-direction: column; }
    .proof-divider { height: 3px; width: 100%; }
  }
</style>
