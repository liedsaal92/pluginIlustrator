<footer class="footer">

  <!-- Top: brand + nav columns -->
  <div class="footer-main">

    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <div class="footer-logo-mark">SF</div>
        <span>SubliFlow</span>
      </a>
      <p class="footer-tagline">
        Automatiza la producción de uniformes deportivos.<br/>
        De horas a minutos.
      </p>
      <div class="footer-social">
        <a href="mailto:hola@subliflow.com" class="social-link">hola@subliflow.com</a>
      </div>
    </div>

    <div class="footer-nav-cols">
      <div class="footer-col">
        <span class="footer-col-title">Producto</span>
        <a href="#proceso">Cómo funciona</a>
        <a href="#features">Features</a>
        <a href="#pricing">Precios</a>
        <a href="#waitlist">Acceso anticipado</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-title">Legal</span>
        <a href="/terminos">Términos de uso</a>
        <a href="/privacidad">Privacidad</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-title">Contacto</span>
        <a href="mailto:hola@subliflow.com">hola@subliflow.com</a>
        <a href="#">Sublimania Studio</a>
      </div>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <span class="footer-copy">© 2026 SubliFlow. Todos los derechos reservados.</span>
    <span class="footer-made">Hecho con ❤ en Argentina</span>
    <a href="#" class="footer-top-link">↑ Volver arriba</a>
  </div>

</footer>

<style>
  .footer {
    background: #0D0D0D;
    color: #fff;
    border-top: 3px solid #0D0D0D;
  }

  /* ─── Main ────────────────────────────── */
  .footer-main {
    display: grid;
    grid-template-columns: 340px 1fr;
    border-bottom: 3px solid #222;
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-brand {
    padding: 64px 48px;
    border-right: 3px solid #222;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 20px;
    font-weight: 800;
    color: #fff;
    text-decoration: none;
  }

  .footer-logo-mark {
    width: 40px;
    height: 40px;
    background: #FFE600;
    border: 2px solid #FFE600;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    font-weight: 500;
    color: #0D0D0D;
    flex-shrink: 0;
  }

  .footer-tagline {
    font-size: 14px;
    color: #666;
    line-height: 1.7;
  }

  .footer-social { margin-top: 4px; }

  .social-link {
    display: inline-block;
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: #FFE600;
    text-decoration: underline;
    transition: color 0.15s;
  }

  .social-link:hover { color: #fff; }

  /* ─── Nav cols ────────────────────────── */
  .footer-nav-cols {
    padding: 64px 56px;
    display: flex;
    gap: 64px;
    justify-content: flex-start;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-width: 120px;
  }

  .footer-col-title {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #FFE600;
    margin-bottom: 4px;
  }

  .footer-col a {
    font-size: 14px;
    color: #555;
    transition: color 0.15s;
  }

  .footer-col a:hover { color: #fff; }

  /* ─── Bottom bar ──────────────────────── */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 56px;
    border-top: none;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .footer-copy,
  .footer-made {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: #333;
  }

  .footer-top-link {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: #555;
    transition: color 0.15s;
    text-decoration: none;
  }

  .footer-top-link:hover { color: #FFE600; }

  /* ─── Responsive ──────────────────────── */
  @media (max-width: 900px) {
    .footer-main { grid-template-columns: 1fr; }
    .footer-brand { border-right: none; border-bottom: 3px solid #222; padding: 48px 32px; }
    .footer-nav-cols { padding: 48px 32px; flex-wrap: wrap; gap: 40px; }
    .footer-bottom { padding: 20px 32px; flex-wrap: wrap; gap: 8px; }
  }

  @media (max-width: 500px) {
    .footer-bottom { justify-content: center; text-align: center; }
  }
</style>
